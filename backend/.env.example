# Локально: PostgreSQL из docker-compose в корне репозитория (postgres:16, user/pass fox, БД foxmotors)
DATABASE_URL="postgresql://fox:fox@localhost:5433/foxmotors"
PORT=3000
NODE_ENV=development
JWT_SECRET="change-me-in-production-min-32-chars-long!!"
JWT_EXPIRES_IN=30m
REFRESH_TOKEN_EXPIRES_DAYS=7
# В development CORS разрешает любой origin (см. app.js) — удобно для http://127.0.0.1 и http://192.168.x.x:3000
# В production обязателен точный origin фронта (или на Render не задавайте — подставится RENDER_EXTERNAL_URL)
CORS_ORIGIN=http://localhost:3000
# RENDER_EXTERNAL_URL задаётся платформой Render автоматически (не прописывать локально)
LLM_BASE_URL=http://127.0.0.1:11434
LLM_MODEL=qwen2.5:7b
# Установите false для работы без LLM (rule-based fallback)
LLM_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_CHAT_IDS=

# Тесты: отдельная БД (создаётся `npm run db:ensure-test` при запущенном Docker или init-скриптом тома)
TEST_DATABASE_URL="postgresql://fox:fox@localhost:5433/foxmotors_test"

# Опционально: полный путь к .ttf с кириллицей для экспорта PDF (иначе ищутся системные DejaVu/Arial)
# PDF_BODY_FONT=
# Название в шапке PDF-отчётов (по умолчанию «Автоассистент»)
# PDF_BRAND_NAME=
